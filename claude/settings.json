{
  "permissions": {
    "allow": [
      "Grep",
      "Glob",
      "Bash(ls *)",
      "Bash(/bin/ls *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(which *)"
    ],
    "deny": [
      "Read(.env*)",
      "Bash(*.env*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "language": "japanese"
}
