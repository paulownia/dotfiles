{
  "permissions": {
    "allow": [
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Bash(*.env*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.netrc)",
      "Read(~/.kube/*)",
      "Read(~/.docker/config.json)",
      "Grep(~/.ssh/*)",
      "Grep(~/.aws/*)",
      "Grep(~/.config/gh/hosts.yml)",
      "Grep(~/.config/gcloud/*)",
      "Grep(~/.gnupg/*)",
      "Grep(~/.netrc)",
      "Grep(~/.kube/*)",
      "Grep(~/.docker/config.json)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "api.github.com"
      ]
    },
    "filesystem": {
      "allowWrite": [],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.netrc",
        "~/.kube",
        "~/.docker/config.json"
      ]
    }
  }
}
