{
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(which *)"
    ],
    "ask":[
    ],
    "deny": [
      "Read(**/.env*)",
      "Bash(*.env*)",
      "Read(~/.ssh/*)",
      "Bash(*.ssh*)",
      "Read(~/.aws/*)",
      "Bash(*.aws*)",
      "Read(~/.config/gh/hosts.yml)",
      "Bash(*.config/gh/hosts*)",
      "Read(~/.config/gcloud/*)",
      "Bash(*.config/gcloud*)",
      "Read(~/.netrc)",
      "Bash(*.netrc*)",
      "Read(~/.gnupg/*)",
      "Bash(*.gnupg*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["//tmp"],
      "denyRead": [
        "**/.env",
        "**/.env.*",
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.netrc"
      ],
      "denyWrite": []
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "www.npmjs.com",
        "pypi.org",
        "files.pythonhosted.org",
        "rubygems.org",
        "crates.io",
        "proxy.golang.org",
        "pkg.go.dev",
        "repo1.maven.org",
        "formulae.brew.sh",
        "qiita.com",
        "zenn.dev",
        "stackoverflow.com",
        "developer.mozilla.org"
      ]
    }
  }
}
