{
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(which *)"
    ],
    "ask":[
    ],
    "deny": [
      "Read(**/.env*)",
      "Bash(*.env*)",
      "Read(~/.ssh/*)",
      "Bash(*.ssh*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "language": "japanese"
}
