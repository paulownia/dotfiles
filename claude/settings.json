{
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(which *)"
    ],
    "ask":[
    ],
    "deny": [
      "Read(**/.env*)",
      "Bash(*.env*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.netrc)",
      "Read(~/.kube/*)",
      "Read(~/.docker/config.json)",
      "Grep(~/.ssh/*)",
      "Grep(~/.aws/*)",
      "Grep(~/.config/gh/hosts.yml)",
      "Grep(~/.config/gcloud/*)",
      "Grep(~/.gnupg/*)",
      "Grep(~/.netrc)",
      "Grep(~/.kube/*)",
      "Grep(~/.docker/config.json)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "~/.claude/projects"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.netrc",
        "~/.kube",
        "~/.docker/config.json"
      ]
    }
  }
}
